// ─── PAGE: HISTORY ────────────────────────────────────────────────────────────
function PageHistory({state}){
  const {liftLogs,runLogs}=state;
  const [tab,setTab]=useState("runs");

  const runs=useMemo(()=>{
    const arr=[];
    Object.entries(runLogs).forEach(([wk,sessions])=>{
      const tw=parseInt(wk.replace("w",""));
      Object.entries(sessions).forEach(([sid,d])=>{
        if(!d?.completed) return;
        arr.push({tw,sid,...d,rd:RUN_DEFS[sid]});
      });
    });
    return arr.sort((a,b)=>(b.date||"").localeCompare(a.date||""));
  },[runLogs]);

  const lifts=useMemo(()=>{
    const arr=[];
    Object.entries(liftLogs).forEach(([wk,sessions])=>{
      const tw=parseInt(wk.replace("w",""));
      Object.entries(sessions).forEach(([sid,d])=>{
        if(!d?.completed) return;
        arr.push({tw,sid,...d,def:LIFTS[sid]});
      });
    });
    return arr.sort((a,b)=>(b.date||"").localeCompare(a.date||""));
  },[liftLogs]);

  const weeklyMi=useMemo(()=>{
    const map={};
    Object.entries(runLogs).forEach(([wk,sessions])=>{
      const tw=parseInt(wk.replace("w",""));
      if(!map[tw]) map[tw]=0;
      Object.values(sessions).forEach(d=>{if(d?.completed&&d.distance) map[tw]+=parseFloat(d.distance)||0;});
    });
    return Object.entries(map).map(([w,m])=>({w:parseInt(w),m:Math.round(m*10)/10})).sort((a,b)=>a.w-b.w).slice(-10);
  },[runLogs]);

  const paceTrend=useMemo(()=>{
    return [...runs].reverse().filter(r=>r.actualPace&&r.actualPace.includes(":")).slice(0,12).map(r=>{
      const [min,sec]=r.actualPace.split(":").map(Number);
      return{date:r.date.slice(5),pace:min+(sec||0)/60};
    });
  },[runs]);

  const totalMi=runs.reduce((s,r)=>s+(parseFloat(r.distance)||0),0);

  const BarChart=({data,color})=>{
    if(!data.length) return <div style={{fontSize:13,color:"var(--t3)",textAlign:"center",padding:16}}>No data yet</div>;
    const max=Math.max(...data.map(d=>d.value),0.1);
    return(
      <div style={{display:"flex",alignItems:"flex-end",gap:4,height:80}}>
        {data.map((d,i)=>(
          <div key={i} style={{flex:1,display:"flex",flexDirection:"column",alignItems:"center",gap:3}}>
            <div style={{fontSize:8,color:"var(--t3)"}}>{d.value}</div>
            <div style={{width:"100%",height:`${(d.value/max)*60}px`,minHeight:2,background:color,borderRadius:"3px 3px 0 0",opacity:.85}}/>
            <div style={{fontSize:8,color:"var(--t3)",whiteSpace:"nowrap"}}>{d.label}</div>
          </div>
        ))}
      </div>
    );
  };

  const LineChart=({data})=>{
    if(data.length<2) return <div style={{fontSize:13,color:"var(--t3)",textAlign:"center",padding:16}}>Log more runs</div>;
    const W=280,H=60,min=Math.min(...data.map(d=>d.pace)),max=Math.max(...data.map(d=>d.pace)),range=max-min||0.1;
    const pts=data.map((d,i)=>({x:(i/(data.length-1))*W,y:H-((d.pace-min)/range)*(H-12)-6}));
    const path=pts.map((p,i)=>`${i===0?"M":"L"}${p.x.toFixed(1)},${p.y.toFixed(1)}`).join(" ");
    return(
      <div>
        <svg viewBox={`0 0 ${W} ${H}`} style={{width:"100%",height:H}}>
          <path d={path} fill="none" stroke="var(--run)" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"/>
          {pts.map((p,i)=><circle key={i} cx={p.x} cy={p.y} r="3" fill="var(--run)"/>)}
        </svg>
        <div style={{display:"flex",justifyContent:"space-between",fontSize:9,color:"var(--t3)",marginTop:4}}>
          <span>{data[0]?.date}</span><span>← faster · slower →</span><span>{data[data.length-1]?.date}</span>
        </div>
      </div>
    );
  };

  return(
    <div style={{padding:"20px 20px 100px"}}>
      <div style={{fontSize:28,fontWeight:800,letterSpacing:"-0.03em",marginBottom:4}}>History</div>
      <div style={{fontSize:13,color:"var(--t2)",marginBottom:14}}>Jun 8, 2026 — present</div>

      <div style={{display:"grid",gridTemplateColumns:"repeat(3,1fr)",gap:8,marginBottom:16}}>
        {[[runs.length,"Runs","var(--run)"],[Math.round(totalMi*10)/10,"Miles","var(--accent)"],[lifts.length,"Sessions","var(--lift)"]].map(([v,l,c])=>(
          <div key={l} style={{background:"var(--s1)",border:"1px solid var(--b1)",borderRadius:"var(--r)",padding:"12px 10px",textAlign:"center"}}>
            <Mono style={{fontSize:20,fontWeight:500,color:c,display:"block"}}>{v}</Mono>
            <div style={{fontSize:10,color:"var(--t3)",textTransform:"uppercase",letterSpacing:"0.08em",marginTop:2}}>{l}</div>
          </div>
        ))}
      </div>

      <div style={{display:"flex",gap:6,marginBottom:14}}>
        {["runs","lifts","charts"].map(t=>(
          <button key={t} onClick={()=>setTab(t)} style={{padding:"7px 16px",borderRadius:20,background:tab===t?"var(--t1)":"var(--s2)",color:tab===t?"var(--bg)":"var(--t2)",border:"none",fontSize:12,fontWeight:700,cursor:"pointer",fontFamily:"Syne,sans-serif",textTransform:"capitalize"}}>{t}</button>
        ))}
      </div>

      {tab==="charts"&&(
        <>
          <Card style={{marginBottom:12}}>
            <ST c="Weekly Mileage Logged"/>
            <BarChart data={weeklyMi.map(w=>({label:`W${w.w}`,value:w.m}))} color="var(--run)"/>
          </Card>
          <Card>
            <ST c="Avg Pace Trend"/>
            <LineChart data={paceTrend}/>
            <div style={{fontSize:11,color:"var(--t3)",marginTop:8}}>Lower = faster. Based on manually logged paces.</div>
          </Card>
        </>
      )}

      {tab==="runs"&&(
        runs.length===0
          ?<div style={{fontSize:13,color:"var(--t3)",textAlign:"center",padding:30}}>No runs logged yet.</div>
          :runs.slice(0,10).map((r,i)=>{
            const tc=typeColor(r.rd?.type),feelObj=FEEL.find(f=>f.v===r.feel);
            return(
              <Card key={i} style={{marginBottom:10}}>
                <SB style={{marginBottom:6}}>
                  <div>
                    <Row style={{gap:6,marginBottom:4}}>{r.rd&&<Pill color={tc} sm>{r.rd.type}</Pill>}<span style={{fontSize:11,color:"var(--t3)"}}>{r.date}</span></Row>
                    <div style={{fontSize:14,fontWeight:700}}>{r.rd?.label||r.sid}</div>
                  </div>
                  <div style={{textAlign:"right"}}>
                    {r.actualPace&&<Mono style={{fontSize:14,fontWeight:500,color:"var(--run)"}}>{r.actualPace}/mi</Mono>}
                    {r.distance&&<div style={{fontSize:11,color:"var(--t3)"}}>{r.distance} mi</div>}
                  </div>
                </SB>
                {feelObj&&<div style={{fontSize:13,marginTop:4}}>{feelObj.e} {feelObj.label}</div>}
                {r.note&&<div style={{fontSize:11,color:"var(--t3)",marginTop:6,fontStyle:"italic",lineHeight:1.5}}>{r.note}</div>}
              </Card>
            );
          })
      )}

      {tab==="lifts"&&(
        lifts.length===0
          ?<div style={{fontSize:13,color:"var(--t3)",textAlign:"center",padding:30}}>No sessions logged yet.</div>
          :lifts.slice(0,8).map((r,i)=>{
            const exLogged=Object.keys(r).filter(k=>!["sessionNote","completed","date","tw","sid","def"].includes(k)&&r[k]?.sets);
            return(
              <Card key={i} style={{marginBottom:10}}>
                <SB style={{marginBottom:8}}>
                  <div><div style={{fontSize:11,color:"var(--t3)"}}>{r.date}</div><div style={{fontSize:14,fontWeight:700,marginTop:2}}>{r.def?.label||r.sid}</div></div>
                  {r.def&&<div style={{width:10,height:10,borderRadius:"50%",background:r.def.color}}/>}
                </SB>
                {exLogged.map(ex=>{
                  const sets=r[ex]?.sets||[];
                  const vol=sets.reduce((s,set)=>s+(parseFloat(set.reps)||0)*(parseFloat(set.weight)||0),0);
                  const avgRir=sets.length?sets.reduce((s,set)=>s+(parseFloat(set.rir)||3),0)/sets.length:null;
                  return(
                    <div key={ex} style={{display:"flex",justifyContent:"space-between",paddingBottom:6,borderBottom:"1px solid var(--b1)",marginBottom:6}}>
                      <div style={{fontSize:12}}>{ex}</div>
                      <Row style={{gap:10}}>
                        {vol>0&&<Mono style={{fontSize:11,color:"var(--t2)"}}>{Math.round(vol).toLocaleString()} vol</Mono>}
                        {avgRir!==null&&<Mono style={{fontSize:11,color:avgRir<=1.5?"var(--ok)":"var(--t3)"}}>RIR {avgRir.toFixed(1)}</Mono>}
                      </Row>
                    </div>
                  );
                })}
                {r.sessionNote&&<div style={{fontSize:11,color:"var(--t3)",fontStyle:"italic",marginTop:4}}>{r.sessionNote}</div>}
              </Card>
            );
          })
      )}
    </div>
  );
}

