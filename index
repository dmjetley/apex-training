            <input type="number" value={newV} onChange={e=>setNewV(Number(e.target.value))} min={vdot} max={55} style={{width:80}}/>
            <Btn onClick={()=>{onUpdate(newV);onDismiss();}} style={{fontSize:12,padding:"8px 14px"}}>Set VDOT {newV}</Btn>
            <Btn v="ghost" onClick={()=>setOpen(false)} style={{fontSize:12,padding:"8px 14px"}}>Cancel</Btn>
          </Row>
      }
    </div>
  );
}

// ─── LIFT LOGGER ──────────────────────────────────────────────────────────────
function LiftLogger({sessionKey,weekKey,liftLogs,targetRir,onSave,onClose}){
  const def=LIFTS[sessionKey];
  const existing=liftLogs[weekKey]?.[sessionKey]||{};
  const [ai,setAi]=useState(0);
  const [exData,setExData]=useState(()=>def.exercises.map(ex=>({
    name:ex.name,repRange:ex.repRange,notes:ex.notes,
    sets:existing[ex.name]?.sets||Array.from({length:ex.sets},()=>({reps:"",weight:"",rir:""})),
  })));
  const [note,setNote]=useState(existing.sessionNote||"");

  const upd=(ei,si,f,v)=>setExData(p=>p.map((e,i)=>i!==ei?e:{...e,sets:e.sets.map((s,j)=>j!==si?s:{...s,[f]:v})}));
  const addSet=ei=>setExData(p=>p.map((e,i)=>i!==ei?e:{...e,sets:[...e.sets,{reps:"",weight:"",rir:""}]}));
  const rmSet=(ei,si)=>setExData(p=>p.map((e,i)=>i!==ei?e:{...e,sets:e.sets.filter((_,j)=>j!==si)}));
  const save=()=>{
    const data={sessionNote:note,completed:true,date:todayStr()};
    exData.forEach(ex=>{data[ex.name]={sets:ex.sets,date:todayStr()};});
    onSave(data);
  };
  const ex=exData[ai];

  return(
    <div style={{position:"fixed",inset:0,background:"var(--bg)",zIndex:300,overflowY:"auto"}}>
      <div style={{padding:"20px 20px 110px"}}>
        <SB style={{marginBottom:12}}>
          <div>
            <div style={{fontSize:11,color:"var(--t3)",marginBottom:4,textTransform:"uppercase",letterSpacing:"0.08em"}}>Lifting</div>
            <div style={{fontSize:24,fontWeight:800,letterSpacing:"-0.02em"}}>{def.label}</div>
          </div>
          <Btn v="ghost" onClick={onClose} style={{padding:"8px 14px",fontSize:12}}>Close</Btn>
        </SB>

        {/* RIR target banner */}
        <div style={{background:`color-mix(in srgb,${LIFT_INTENSITY_COLOR[Math.ceil(4-targetRir)||1]||"var(--lift)"} 12%,var(--s1))`,border:`1px solid color-mix(in srgb,${LIFT_INTENSITY_COLOR[Math.ceil(4-targetRir)||1]||"var(--lift)"} 25%,transparent)`,borderRadius:"var(--r2)",padding:"10px 14px",marginBottom:12}}>
          <Row>
            <Mono style={{fontSize:20,fontWeight:500,color:LIFT_INTENSITY_COLOR[Math.ceil(4-targetRir)||1]||"var(--lift)"}}>{targetRir} RIR</Mono>
            <div>
              <div style={{fontSize:13,fontWeight:600}}>Target this week</div>
              <div style={{fontSize:11,color:"var(--t3)"}}>Stop each set with {targetRir} rep{targetRir!==1?"s":""} left in the tank</div>
            </div>
          </Row>
        </div>

        <ScienceNote text={LIFT_SCIENCE[def.scienceKey]}/>

        <div style={{display:"flex",gap:6,overflowX:"auto",marginBottom:14,paddingBottom:2,scrollbarWidth:"none"}}>
          {exData.map((e,idx)=>{
            const filled=e.sets.filter(s=>s.reps).length;
            return <button key={idx} onClick={()=>setAi(idx)} style={{flexShrink:0,padding:"7px 14px",borderRadius:20,background:ai===idx?def.color:"var(--s2)",color:ai===idx?"#080809":"var(--t2)",border:"none",fontSize:12,fontWeight:600,cursor:"pointer"}}>
              {e.name.split(" ")[0]}{filled>0&&<span style={{opacity:.6,fontSize:10,marginLeft:4}}>{filled}/{e.sets.length}</span>}
            </button>;
          })}
        </div>

        <Card style={{border:`1px solid color-mix(in srgb,${def.color} 25%,transparent)`,marginBottom:10}}>
          <SB style={{marginBottom:8}}>
            <div>
              <div style={{fontSize:16,fontWeight:700}}>{ex.name}</div>
              {ex.notes&&<div style={{fontSize:11,color:"var(--t3)",marginTop:2}}>{ex.notes}</div>}
            </div>
            <Pill color={def.color}>{ex.repRange}</Pill>
          </SB>
          {LIFT_EX_NOTES[ex.name]&&(
            <div style={{fontSize:11,color:"var(--t3)",background:"var(--s3)",borderRadius:6,padding:"6px 10px",marginBottom:10,lineHeight:1.6,display:"flex",gap:6,alignItems:"flex-start"}}>
              <span style={{flexShrink:0,marginTop:1}}>{Ic.info()}</span><span>{LIFT_EX_NOTES[ex.name]}</span>
            </div>
          )}
          <div style={{display:"grid",gridTemplateColumns:"24px 1fr 1fr 52px 24px",gap:6,marginBottom:6}}>
            {["#","Reps","Weight","RIR",""].map((h,i)=><div key={i} style={{fontSize:10,color:"var(--t3)",textTransform:"uppercase",letterSpacing:"0.06em",textAlign:"center"}}>{h}</div>)}
          </div>
          {ex.sets.map((set,si)=>(
            <div key={si} style={{display:"grid",gridTemplateColumns:"24px 1fr 1fr 52px 24px",gap:6,marginBottom:6,alignItems:"center"}}>
              <Mono style={{fontSize:11,color:"var(--t3)",textAlign:"center"}}>{si+1}</Mono>
              <input type="number" inputMode="numeric" value={set.reps}   onChange={e=>upd(ai,si,"reps",  e.target.value)} placeholder="—" style={{textAlign:"center",padding:"8px 4px"}}/>
              <input type="number" inputMode="decimal" value={set.weight} onChange={e=>upd(ai,si,"weight",e.target.value)} placeholder="—" style={{textAlign:"center",padding:"8px 4px"}}/>
              <input type="number" inputMode="numeric" value={set.rir}    onChange={e=>upd(ai,si,"rir",   e.target.value)} placeholder={targetRir} min={0} max={5} style={{textAlign:"center",padding:"8px 4px"}}/>
              <button onClick={()=>rmSet(ai,si)} style={{background:"none",color:"var(--t3)",display:"flex",alignItems:"center",justifyContent:"center"}}>{Ic.trash()}</button>
            </div>
          ))}
          <Btn v="ghost" onClick={()=>addSet(ai)} style={{width:"100%",padding:"8px",fontSize:12,marginTop:4}}>{Ic.plus()} Add Set</Btn>
        </Card>

        <Card style={{marginBottom:14}}>
          <ST c="Session Note"/>
          <textarea value={note} onChange={e=>setNote(e.target.value)} placeholder="How did it feel? Any adjustments?" style={{resize:"none",height:72}}/>
        </Card>
        <Btn onClick={save} style={{width:"100%",padding:14,fontSize:14}}>{Ic.check()} Save Session</Btn>
      </div>
    </div>
  );
}

// ─── RUN DETAIL ───────────────────────────────────────────────────────────────
function RunDetail({item,weekKey,vdot,runLogs,onSave,onClose}){
  const {runDef,miles}=item;
  const paces=VDOT_PACES[vdot]||VDOT_PACES[46];
  const segs=runDef.getSegs(paces,miles);
  const existing=runLogs[weekKey]?.[item.id]||{};
  const tc=typeColor(runDef.type);
  const segTotal=Math.round(segs.reduce((s,seg)=>s+(seg.miles||0),0)*10)/10;

  const [feel,setFeel]=useState(existing.feel||null);
  const [note,setNote]=useState(existing.note||"");
  const [ap,setAp]=useState(existing.actualPace||"");
  const [dist,setDist]=useState(existing.distance||"");
  const save=()=>onSave({feel,note,actualPace:ap,distance:dist,completed:true,date:todayStr()});
  const isKey=l=>["Piece","Blk","MP","Pickup","×","Tempo","Strides"].some(k=>l.includes(k));

  return(
    <div style={{position:"fixed",inset:0,background:"var(--bg)",zIndex:300,overflowY:"auto"}}>
      <div style={{padding:"20px 20px 110px"}}>
        <SB style={{marginBottom:12}}>
          <div>
            <div style={{fontSize:11,color:"var(--t3)",marginBottom:4,textTransform:"uppercase",letterSpacing:"0.08em"}}>Running · {fmtFull(item.date)}</div>
            <div style={{fontSize:22,fontWeight:800,letterSpacing:"-0.02em",lineHeight:1.2}}>{runDef.label}</div>
          </div>
          <Btn v="ghost" onClick={onClose} style={{padding:"8px 14px",fontSize:12}}>Close</Btn>
        </SB>
        <Row style={{marginBottom:12}}>
          <Pill color={tc}>{runDef.type}</Pill>
          <Pill color="var(--t3)">{miles} mi</Pill>
          <Pill color="var(--t3)">VDOT {vdot}</Pill>
        </Row>
        <div style={{fontSize:13,color:"var(--t2)",marginBottom:12,fontStyle:"italic",lineHeight:1.6}}>{runDef.desc}</div>
        <ScienceNote text={runDef.scienceNote}/>

        <Card style={{marginBottom:12}}>
          <SB style={{marginBottom:10}}>
            <ST c="Workout Structure"/>
            <div style={{fontSize:10,color:"var(--t3)"}}>Total: {segTotal} mi</div>
          </SB>
          {segs.map((seg,idx)=>(
            <div key={idx} style={{display:"flex",gap:12,paddingBottom:idx<segs.length-1?12:0,borderBottom:idx<segs.length-1?"1px solid var(--b1)":"none",marginBottom:idx<segs.length-1?12:0}}>
              <div style={{width:3,borderRadius:3,background:isKey(seg.label)?tc:"var(--b2)",flexShrink:0,alignSelf:"stretch"}}/>
              <div style={{flex:1}}>
                <SB>
                  <div style={{fontSize:13,fontWeight:600}}>{seg.label}</div>
                  <Mono style={{fontSize:13,color:isKey(seg.label)?tc:"var(--t3)"}}>{seg.pace}</Mono>
                </SB>
                <div style={{fontSize:11,color:"var(--t3)",marginTop:2}}>{seg.dist} · {seg.feel}</div>
              </div>
            </div>
          ))}
        </Card>

        <Card style={{background:`color-mix(in srgb,${tc} 5%,var(--s1))`,border:`1px solid color-mix(in srgb,${tc} 18%,transparent)`,marginBottom:12}}>
          <ST c={`Paces — VDOT ${vdot}`}/>
          <div style={{display:"grid",gridTemplateColumns:"1fr 1fr 1fr",gap:10}}>
            {[["Easy",paces.E,"var(--run)"],["Marathon",paces.M,"var(--accent)"],["Threshold",paces.T,"var(--warn)"]].map(([l,p,c])=>(
              <div key={l} style={{textAlign:"center"}}>
                <div style={{fontSize:10,color:"var(--t3)",textTransform:"uppercase",letterSpacing:"0.06em",marginBottom:4}}>{l}</div>
                <Mono style={{fontSize:14,fontWeight:500,color:c}}>{p}</Mono>
              </div>
            ))}
          </div>
        </Card>

        <Card style={{marginBottom:12}}>
          <ST c="Log This Run"/>
          <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:10,marginBottom:14}}>
            <div><div style={{fontSize:11,color:"var(--t3)",marginBottom:5}}>Avg Pace (min/mi)</div><input value={ap} onChange={e=>setAp(e.target.value)} placeholder="7:30"/></div>
            <div><div style={{fontSize:11,color:"var(--t3)",marginBottom:5}}>Distance (mi)</div><input type="number" inputMode="decimal" value={dist} onChange={e=>setDist(e.target.value)} placeholder={miles}/></div>
          </div>
          <div style={{fontSize:11,color:"var(--t3)",marginBottom:8}}>How did it feel?</div>
          <div style={{display:"flex",gap:6,flexWrap:"wrap",marginBottom:14}}>
            {FEEL.map(f=><button key={f.v} onClick={()=>setFeel(f.v)} style={{padding:"6px 10px",borderRadius:20,background:feel===f.v?tc:"var(--s3)",color:feel===f.v?"#080809":"var(--t2)",border:"none",fontSize:12,fontWeight:600,cursor:"pointer",fontFamily:"Syne,sans-serif"}}>{f.e} {f.label}</button>)}
          </div>
          <div style={{fontSize:11,color:"var(--t3)",marginBottom:6}}>Notes</div>
          <textarea value={note} onChange={e=>setNote(e.target.value)} placeholder="Conditions, how legs felt, pace adjustments..." style={{resize:"none",height:72}}/>
        </Card>
        <Btn onClick={save} style={{width:"100%",padding:14,fontSize:14}}>{Ic.check()} Log Run</Btn>
      </div>
    </div>
  );
}

// ─── PAGE: WEEK ───────────────────────────────────────────────────────────────
function PageWeek({state,dispatch,setTab}){
  const {vdot,viewWeek,liftLogs,runLogs,vdotPromptDismissed}=state;
  const [modal,setModal]=useState(null);
  const tw=viewWeek;
  const key=wkKey(tw);
  const rwInfo=getRunningWeekInfo(tw);
  const {blockNum,weekInBlock,targetMiles,isLastWeekOfBlock}=rwInfo;
  const def=getWeekDef(blockNum,weekInBlock);
  const liftRir=LIFT_RIR_BY_WEEK[weekInBlock];
  const liftLabel=LIFT_INTENSITY_LABEL[weekInBlock];
  const liftColor=LIFT_INTENSITY_COLOR[weekInBlock];
  const schedule=useMemo(()=>buildSchedule(tw),[tw]);
  const nw=nowWeek();
  const isCurrent=tw===nw;

  // Block boundary: show VDOT prompt if the previous week was the last of a block
  const prevBlockEndWeek = tw - 1;
  const showVdotPrompt = isCurrent
    && prevBlockEndWeek >= 1
    && getRunningWeekInfo(prevBlockEndWeek).isLastWeekOfBlock
    && !vdotPromptDismissed.includes(prevBlockEndWeek);

  const isDone=item=>item.type==="lift"?!!liftLogs[key]?.[item.id]?.completed:!!runLogs[key]?.[item.id]?.completed;
  const doneCount=schedule.filter(isDone).length;
  const handleSaveLift=data=>{dispatch({type:"SAVE_LIFT",wk:key,session:modal.id,data});setModal(null);};
  const handleSaveRun=data=>{dispatch({type:"SAVE_RUN",wk:key,session:modal.id,data});setModal(null);};
  const miSum=Math.round((()=>{const mi=allocateMiles(targetMiles,blockNum,weekInBlock);return mi.easy+mi.Q1+mi.easy2+mi.Q2;})() * 10)/10;

  return(
    <div style={{padding:"20px 20px 100px"}}>
      {modal?.type==="lift"&&<LiftLogger sessionKey={modal.liftKey} weekKey={key} liftLogs={liftLogs} targetRir={liftRir} onSave={handleSaveLift} onClose={()=>setModal(null)}/>}
      {modal?.type==="run" &&<RunDetail  item={modal} weekKey={key} vdot={vdot} runLogs={runLogs} onSave={handleSaveRun} onClose={()=>setModal(null)}/>}

      <SB style={{marginBottom:4}}>
        <div>
          <div style={{fontSize:11,color:"var(--t3)",textTransform:"uppercase",letterSpacing:"0.08em"}}>
            Block {blockNum}/6 · Week {weekInBlock}/4{isCurrent&&<span style={{color:"var(--accent)"}}> · Current</span>}
          </div>
          <div style={{fontSize:26,fontWeight:800,letterSpacing:"-0.03em",marginTop:2}}>
            {fmtShort(weekStart(tw))} – {fmtShort(weekEnd(tw))}
          </div>
        </div>
        <div style={{textAlign:"right"}}>
          <Mono style={{fontSize:22,fontWeight:500,color:doneCount===schedule.length?"var(--ok)":"var(--accent)"}}>
            {doneCount}<span style={{fontSize:14,color:"var(--t3)"}}>/{schedule.length}</span>
          </Mono>
          <div style={{fontSize:10,color:"var(--t3)"}}>DONE</div>
        </div>
      </SB>

      {showVdotPrompt&&(
        <VdotPrompt
          vdot={vdot}
          blockEndWeek={prevBlockEndWeek}
          dismissed={false}
          onDismiss={()=>dispatch({type:"DISMISS_VDOT_PROMPT",blockEnd:prevBlockEndWeek})}
          onUpdate={v=>dispatch({type:"VDOT",v})}
        />
      )}

      {/* Running + Lifting intensity summary banner */}
      <button onClick={()=>setTab("cycle")} style={{width:"100%",background:"var(--s1)",border:"1px solid var(--b1)",borderRadius:"var(--r)",padding:"12px 14px",marginBottom:12,textAlign:"left",cursor:"pointer"}}>
        <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:10,marginBottom:8}}>
          <div style={{background:`color-mix(in srgb,${def.color} 10%,var(--s3))`,borderRadius:"var(--r2)",padding:"8px 10px"}}>
            <div style={{fontSize:10,color:"var(--t3)",textTransform:"uppercase",letterSpacing:"0.06em",marginBottom:3}}>Running</div>
            <div style={{fontSize:13,fontWeight:700,color:def.color}}>{def.label}</div>
            <Mono style={{fontSize:12,color:def.color}}>{targetMiles} mi · {miSum} planned</Mono>
          </div>
          <div style={{background:`color-mix(in srgb,${liftColor} 10%,var(--s3))`,borderRadius:"var(--r2)",padding:"8px 10px"}}>
            <div style={{fontSize:10,color:"var(--t3)",textTransform:"uppercase",letterSpacing:"0.06em",marginBottom:3}}>Lifting</div>
            <div style={{fontSize:13,fontWeight:700,color:liftColor}}>{liftLabel}</div>
            <Mono style={{fontSize:12,color:liftColor}}>Target {liftRir} RIR</Mono>
          </div>
        </div>
        <div style={{fontSize:11,color:"var(--t3)"}}>{def.desc} <span style={{color:"var(--accent)"}}>View cycle →</span></div>
      </button>

      <div style={{display:"grid",gridTemplateColumns:"repeat(3,1fr)",gap:8,marginBottom:14}}>
        {[["VDOT",vdot,"var(--accent)"],["Miles",targetMiles,"var(--run)"],["Lifts",4,"var(--lift)"]].map(([l,v,c])=>(
          <div key={l} style={{background:"var(--s1)",border:"1px solid var(--b1)",borderRadius:"var(--r)",padding:"10px",textAlign:"center"}}>
            <Mono style={{fontSize:20,fontWeight:500,color:c,display:"block"}}>{v}</Mono>
            <div style={{fontSize:10,color:"var(--t3)",textTransform:"uppercase",letterSpacing:"0.08em",marginTop:2}}>{l}</div>
          </div>
        ))}
      </div>

      <ST c="Schedule"/>
      {schedule.map((item,idx)=>{
        const done=isDone(item);
        const color=item.type==="lift"?LIFTS[item.liftKey]?.color:item.runDef?.color||"var(--run)";
        const isTdy=toYMD(item.date)===todayStr();
        return(
          <button key={idx} onClick={()=>setModal(item)} style={{width:"100%",background:done?"color-mix(in srgb,var(--ok) 8%,var(--s1))":"var(--s1)",border:`1px solid ${done?"color-mix(in srgb,var(--ok) 25%,transparent)":isTdy?"color-mix(in srgb,var(--accent) 40%,transparent)":"var(--b1)"}`,borderRadius:"var(--r)",padding:"12px 14px",marginBottom:8,display:"flex",alignItems:"center",gap:12,textAlign:"left",cursor:"pointer"}}>
            <div style={{width:36,height:36,borderRadius:10,background:`color-mix(in srgb,${color} 15%,transparent)`,display:"flex",alignItems:"center",justifyContent:"center",color,flexShrink:0}}>
              {item.type==="run"?Ic.run():Ic.lift()}
            </div>
            <div style={{flex:1,minWidth:0}}>
              <Row style={{gap:6,marginBottom:2}}>
                <span style={{fontSize:11,color:isTdy?"var(--accent)":"var(--t3)"}}>{item.day} {fmtMD(item.date)}</span>
                {isTdy&&<Pill color="var(--accent)" sm>Today</Pill>}
              </Row>
              <div style={{fontSize:14,fontWeight:700,whiteSpace:"nowrap",overflow:"hidden",textOverflow:"ellipsis"}}>{item.label}</div>
              {item.type==="run"&&<div style={{fontSize:11,color:"var(--t3)",marginTop:1}}>{item.miles} mi</div>}
              {item.type==="lift"&&<div style={{fontSize:11,color:liftColor,marginTop:1}}>{liftLabel} · {liftRir} RIR</div>}
            </div>
            <Row style={{gap:6,flexShrink:0}}>
              {done&&<span style={{color:"var(--ok)"}}>{Ic.check()}</span>}
              <span style={{color:"var(--t3)"}}>{Ic.right()}</span>
            </Row>
          </button>
        );
      })}

      <SB style={{marginTop:14}}>
        <Btn v="ghost" onClick={()=>dispatch({type:"VIEW_WEEK",w:Math.max(1,tw-1)})} style={{fontSize:12,padding:"9px 14px"}}>{Ic.left()} Prev</Btn>
        <button onClick={()=>dispatch({type:"VIEW_WEEK",w:nw})} style={{background:"none",color:"var(--t3)",fontSize:11,fontFamily:"Syne,sans-serif",cursor:"pointer"}}>
          {isCurrent?"Current week":"→ Current week"}
        </button>
        <Btn v="ghost" onClick={()=>dispatch({type:"VIEW_WEEK",w:tw+1})} style={{fontSize:12,padding:"9px 14px"}}>Next {Ic.right()}</Btn>
      </SB>
    </div>
  );
}

// ─── PAGE: CYCLE ──────────────────────────────────────────────────────────────
function PageCycle({state,dispatch,setTab}){
  const {vdot}=state;
  const nw=nowWeek();
  const paces=VDOT_PACES[vdot]||VDOT_PACES[46];
  const currentRwInfo=getRunningWeekInfo(nw);

  // Determine which 4-week block we're in within the 24-week super-cycle
  const posIn24=((nw-1)%24);
  const currentBlockIdx=Math.floor(posIn24/4);
  const blockStartTw=nw-currentRwInfo.weekInBlock+1; // first week of current block

  return(
    <div style={{padding:"20px 20px 100px"}}>
      <div style={{fontSize:28,fontWeight:800,letterSpacing:"-0.03em",marginBottom:4}}>Cycle Plan</div>
      <div style={{fontSize:13,color:"var(--t2)",marginBottom:18}}>6-block, 24-week program · VDOT {vdot}</div>

      {/* Current block detail */}
      {[0,1,2,3].map(offset=>{
        const tw=blockStartTw+offset;
        const rwi=getRunningWeekInfo(tw);
        const {blockNum,weekInBlock,targetMiles}=rwi;
        const wdef=getWeekDef(blockNum,weekInBlock);
        const liftRir=LIFT_RIR_BY_WEEK[weekInBlock];
        const liftLabel=LIFT_INTENSITY_LABEL[weekInBlock];
        const liftColor=LIFT_INTENSITY_COLOR[weekInBlock];
        const isActive=tw===nw;
        const q1d=RUN_DEFS[wdef.Q1type];
        const q2d=RUN_DEFS[wdef.Q2type];
        const mi=allocateMiles(targetMiles,blockNum,weekInBlock);
        const miSum=Math.round((mi.easy+mi.Q1+mi.easy2+mi.Q2)*10)/10;
        return(
          <button key={offset} onClick={()=>{dispatch({type:"VIEW_WEEK",w:tw});setTab("week");}} style={{width:"100%",background:isActive?`color-mix(in srgb,${wdef.color} 8%,var(--s1))`:"var(--s1)",border:`1px solid ${isActive?`color-mix(in srgb,${wdef.color} 30%,transparent)`:"var(--b1)"}`,borderRadius:"var(--r)",padding:14,marginBottom:10,textAlign:"left",cursor:"pointer"}}>
            <SB style={{marginBottom:10}}>
              <Row>
                <div style={{width:26,height:26,borderRadius:7,background:`color-mix(in srgb,${wdef.color} 20%,transparent)`,display:"flex",alignItems:"center",justifyContent:"center",flexShrink:0}}>
                  <Mono style={{fontSize:12,fontWeight:600,color:wdef.color}}>{weekInBlock}</Mono>
                </div>
                <div>
                  <div style={{fontSize:14,fontWeight:700}}>Week {weekInBlock} — {wdef.label}</div>
                  <div style={{fontSize:11,color:"var(--t3)"}}>{fmtShort(weekStart(tw))} – {fmtShort(weekEnd(tw))}</div>
                </div>
              </Row>
              <Row style={{gap:6}}>
                {isActive&&<Pill color={wdef.color} sm>Active</Pill>}
              </Row>
            </SB>

            {/* Run + Lift side by side */}
