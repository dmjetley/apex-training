<script>
const STRAVA_CLIENT_ID     = "247028";
const STRAVA_CLIENT_SECRET = "00a9a7ca70c325a2e3a4f06de6a023f1a6fa1491";
const STRAVA_REDIRECT_URI  = "https://dmjetley.github.io/apex-training/";
const STRAVA_SCOPE         = "activity:read_all";

// ─── STRAVA TOKEN MANAGEMENT ──────────────────────────────────────────────
const StravaAuth = {
  getTokens() {
    try { return JSON.parse(localStorage.getItem("stravaTokens") || "null"); } catch { return null; }
  },
  saveTokens(data) {
    localStorage.setItem("stravaTokens", JSON.stringify({
      accessToken:  data.access_token,
      refreshToken: data.refresh_token,
      expiresAt:    data.expires_at,
      athlete:      data.athlete,
    }));
  },
  clearTokens() { localStorage.removeItem("stravaTokens"); },
  isExpired() {
    const t = this.getTokens();
    if (!t) return true;
    return Date.now() / 1000 > t.expiresAt - 300; // 5-min buffer
  },
  async refreshIfNeeded() {
    if (!this.isExpired()) return this.getTokens().accessToken;
    const t = this.getTokens();
    if (!t?.refreshToken) return null;
    try {
      const res = await fetch("https://www.strava.com/oauth/token", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          client_id:     STRAVA_CLIENT_ID,
          client_secret: STRAVA_CLIENT_SECRET,
          refresh_token: t.refreshToken,
          grant_type:    "refresh_token",
        }),
      });
      const data = await res.json();
      if (data.access_token) { this.saveTokens(data); return data.access_token; }
    } catch(e) { console.error("Token refresh failed", e); }
    return null;
  },
  async fetchActivities(after) {
    const token = await this.refreshIfNeeded();
    if (!token) return [];
    const url = `https://www.strava.com/api/v3/athlete/activities?per_page=50&after=${after}`;
    try {
      const res  = await fetch(url, { headers: { Authorization: `Bearer ${token}` } });
      const data = await res.json();
      return Array.isArray(data) ? data : [];
    } catch(e) { console.error("Strava fetch failed", e); return []; }
  },
  startOAuth() {
    const params = new URLSearchParams({
      client_id:     STRAVA_CLIENT_ID,
      redirect_uri:  STRAVA_REDIRECT_URI,
      response_type: "code",
      approval_prompt:"auto",
      scope:         STRAVA_SCOPE,
    });
    window.location.href = `https://www.strava.com/oauth/authorize?${params}`;
  },
  async handleCallback(code) {
    const res = await fetch("https://www.strava.com/oauth/token", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({
        client_id:     STRAVA_CLIENT_ID,
        client_secret: STRAVA_CLIENT_SECRET,
        code,
        grant_type: "authorization_code",
      }),
    });
    const data = await res.json();
    if (data.access_token) {
      this.saveTokens(data);
      // Clean URL
      window.history.replaceState({}, "", STRAVA_REDIRECT_URI);
      return true;
    }
    return false;
  },
};

// Handle OAuth callback on page load
(async () => {
  const params = new URLSearchParams(window.location.search);
  const code = params.get("code");
  const error = params.get("error");
  if (error) { window.history.replaceState({}, "", STRAVA_REDIRECT_URI); return; }
  if (code) {
    await StravaAuth.handleCallback(code);
    // Reload to trigger app re-render with connected state
    window.location.replace(STRAVA_REDIRECT_URI);
  }
})();
</script>

